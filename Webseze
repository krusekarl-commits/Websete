<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Werbung hier</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
    overflow:hidden;
    background:#f2f2f2;
}

/* STARTSEITE */

#home{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
}

#adButton{
    background:red;
    color:white;
    border:none;
    padding:30px 60px;
    font-size:35px;
    border-radius:20px;
    cursor:pointer;
    transition:0.2s;
    box-shadow:0 8px 20px rgba(0,0,0,0.3);
}

#adButton:hover{
    transform:scale(1.08);
}

.subtitle{
    margin-top:20px;
    font-size:28px;
    font-weight:bold;
    color:black;
}

/* PRANK */

#prank{
    display:none;
    position:fixed;
    inset:0;
    background:black;
    justify-content:center;
    align-items:center;
    flex-direction:column;
}

/* AFFE */

.monkey{
    position:relative;
    width:320px;
    height:420px;
}

/* KOPF */

.face{
    width:260px;
    height:260px;
    background:#5c4033;
    border-radius:50%;
    position:absolute;
    top:20px;
    left:30px;
}

/* OHREN */

.ear{
    width:60px;
    height:60px;
    background:#5c4033;
    border-radius:50%;
    position:absolute;
    top:70px;
}

.ear.left{
    left:-20px;
}

.ear.right{
    right:-20px;
}

/* AUGEN */

.eye{
    width:35px;
    height:35px;
    background:white;
    border-radius:50%;
    position:absolute;
    top:90px;
}

.eye::after{
    content:"";
    width:15px;
    height:15px;
    background:black;
    border-radius:50%;
    position:absolute;
    top:10px;
    left:10px;
}

.eye.left{
    left:70px;
}

.eye.right{
    right:70px;
}

/* MUND */

.mouth{
    width:90px;
    height:40px;
    border-bottom:6px solid black;
    border-radius:50%;
    position:absolute;
    bottom:60px;
    left:85px;
}

/* HAND */

.hand{
    position:absolute;
    bottom:-20px;
    left:90px;
}

/* FINGER */

.finger{
    width:35px;
    background:#d6b89b;
    border-radius:20px;
    position:absolute;
}

.middle{
    height:170px;
    left:40px;
    bottom:0;
}

.side1{
    height:90px;
    left:0;
    bottom:0;
}

.side2{
    height:90px;
    left:80px;
    bottom:0;
}

/* ZURÜCK BUTTON */

#backButton{
    position:absolute;
    bottom:30px;
    background:red;
    color:white;
    border:none;
    padding:18px 35px;
    font-size:24px;
    border-radius:15px;
    cursor:pointer;
    transition:0.2s;
}

#backButton:hover{
    transform:scale(1.05);
}

</style>
</head>

<body>

<!-- STARTSEITE -->

<div id="home">

    <button id="adButton">
        💰 KLICK FÜR WERBUNG 💰
    </button>

    <div class="subtitle">
        Werbung hier
    </div>

</div>

<!-- PRANK -->

<div id="prank">

    <div class="monkey">

        <div class="face">

            <div class="ear left"></div>
            <div class="ear right"></div>

            <div class="eye left"></div>
            <div class="eye right"></div>

            <div class="mouth"></div>

        </div>

        <div class="hand">
            <div class="finger side1"></div>
            <div class="finger middle"></div>
            <div class="finger side2"></div>
        </div>

    </div>

    <button id="backButton">
        ⬅ ZURÜCK
    </button>

</div>

<script>

const adButton = document.getElementById("adButton");
const prank = document.getElementById("prank");
const home = document.getElementById("home");
const backButton = document.getElementById("backButton");

adButton.addEventListener("click", () => {

    home.style.display = "none";
    prank.style.display = "flex";

});

backButton.addEventListener("click", () => {

    prank.style.display = "none";
    home.style.display = "flex";

});

</script>

</body>
</html>